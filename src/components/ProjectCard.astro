---
import BoxFrame from "./BoxFrame.astro";

interface Props {
  project: {
    title: string;
    summary: string;
    repo?: string;
    post?: string;
    stack: string[];
    status: "active" | "archived" | "wip";
    date: Date;
  };
  base?: string;
  /** Im CV-Kontext: nur Header + Summary, kein Markdown-Body. */
  compact?: boolean;
}

const { project, base = "", compact = false } = Astro.props;

const statusColor = (s: string) =>
  s === "active" ? "ok" : s === "wip" ? "warn" : "muted";

const year = project.date.getFullYear();
---

<BoxFrame title={project.title}>
  <p class="muted" style="margin-top:0">
    <span class={statusColor(project.status)}>[{project.status}]</span>
    <span> &middot; {year}</span>
    {
      project.stack.length > 0 && (
        <span> &middot; {project.stack.join(" / ")}</span>
      )
    }
    {
      project.repo && (
        <span>
          {" "}
          &middot; <a href={project.repo}>repo</a>
        </span>
      )
    }
    {
      project.post && (
        <span>
          {" "}
          &middot; <a href={`${base}${project.post}`}>writeup</a>
        </span>
      )
    }
  </p>
  <p>{project.summary}</p>
  {!compact && <slot />}
</BoxFrame>
