---
import "../styles/global.css";
import "../styles/print.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}
const SITE_TITLE = "Filip Zielinski // cybersec notebook";
const SITE_DESCRIPTION =
  "Cybersecurity notebook by Filip Zieliński (nau7ilus): CTF writeups, bug-bounty notes and side-projects from web, mobile and reverse-engineering challenges.";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const {
  title,
  description = SITE_DESCRIPTION,
  ogImage = `${base}/og.png`,
} = Astro.props;
const fullTitle = title ? `${title} — ${SITE_TITLE}` : SITE_TITLE;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
const path = Astro.url.pathname;
const isActive = (p: string) =>
  p === "/"
    ? path === "/" || path === ""
    : path === p || path.startsWith(p + "/");
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark light" />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE_TITLE}
      href={`${base}/rss.xml`}
    />
    <link rel="sitemap" href={`${base}/sitemap.xml`} />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />

    <ClientRouter />
  </head>
  <body>
    <nav class="topbar" aria-label="Hauptnavigation">
      <div class="row">
        <a href={`${base}/`} aria-current={isActive("/") ? "page" : undefined}
          >[home]</a
        >
        <a
          href={`${base}/posts`}
          aria-current={isActive("/posts") ? "page" : undefined}>[posts]</a
        >
        <a
          href={`${base}/projects`}
          aria-current={isActive("/projects") ? "page" : undefined}
          >[projects]</a
        >
        <a
          href={`${base}/cv`}
          aria-current={isActive("/cv") ? "page" : undefined}>[cv]</a
        >
        <a href={`${base}/rss.xml`}>[rss]</a>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer class="bottom">
      <div class="row">
        <span
          >&copy; {new Date().getFullYear()} nau7ilus &mdash; built with <a
            href="https://astro.build">Astro</a
          ></span
        >
        <span>
          <a href={`${base}/pgp.txt`}>[pgp]</a>
          <a
            href={`${base}/.well-known/security.txt`}
            style="margin-left:0.6rem">[security.txt]</a
          >
        </span>
      </div>
    </footer>
    <script is:inline src={`${base}/copy-buttons.js`}></script>
  </body>
</html>
