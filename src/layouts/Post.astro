---
import Base from "./Base.astro";
import TagChip from "../components/TagChip.astro";
import BoxFrame from "../components/BoxFrame.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  category: string;
  tags: string[];
  disclosure?: "public" | "permission-granted" | "redacted";
  /** Post id, used to build the per-post OG image URL. */
  slug: string;
}
const { title, description, date, updated, category, tags, disclosure, slug } =
  Astro.props;
const iso = date.toISOString().slice(0, 10);
const updatedIso = updated?.toISOString().slice(0, 10);

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const ogImage = `${base}/og/${slug}.png`;
const articleUrl = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageAbs = new URL(ogImage, Astro.site).toString();

const ldJson = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  datePublished: date.toISOString(),
  ...(updated ? { dateModified: updated.toISOString() } : {}),
  author: {
    "@type": "Person",
    name: "Filip Zieliński",
    url: Astro.site?.toString(),
  },
  image: ogImageAbs,
  mainEntityOfPage: { "@type": "WebPage", "@id": articleUrl },
  keywords: [category, ...tags].join(", "),
};
---

<Base title={title} description={description} ogImage={ogImage}>
  <article>
    <header>
      <p class="muted" style="margin-bottom:0.25rem">
        <time datetime={iso}>{iso}</time>
        <span> &middot; [{category}]</span>
        {
          updated && (
            <span>
              {" "}
              &middot; updated <time datetime={updatedIso}>{updatedIso}</time>
            </span>
          )
        }
      </p>
      <h1 style="margin-top:0.25rem">{title}</h1>
      <p class="muted">{description}</p>
      {
        tags.length > 0 && (
          <p class="tag-list" style="margin-bottom:1rem">
            {tags.map((t) => (
              <TagChip tag={t} />
            ))}
          </p>
        )
      }
      {
        disclosure === "redacted" && (
          <BoxFrame title="disclosure">
            <p class="warn" style="margin:0">
              Der Vendor hat einer Veröffentlichung zugestimmt, bittet aber
              darum, namentlich nicht genannt zu werden. Domain, Pfad-Details
              und Parameter-Name sind entsprechend generalisiert. Die
              Bug-Klasse, der Vector und der Disclosure-Verlauf bleiben akkurat.
            </p>
          </BoxFrame>
        )
      }
      {
        disclosure === "permission-granted" && (
          <p class="ok muted">disclosure: vendor permission granted</p>
        )
      }
    </header>
    <hr />
    <div class="post-content">
      <slot />
    </div>
  </article>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(ldJson)}
  />
</Base>
