---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import TagChip from '../../components/TagChip.astro';
import Prompt from '../../components/Prompt.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const tagSet = new Set<string>();
for (const p of posts) for (const t of p.data.tags) tagSet.add(t);
const tags = [...tagSet].sort();

const byYear = new Map<number, typeof posts>();
for (const p of posts) {
  const y = p.data.date.getUTCFullYear();
  if (!byYear.has(y)) byYear.set(y, [] as typeof posts);
  byYear.get(y)!.push(p);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---
<Base title="posts" description="All writeups, organised by year.">
  <p><Prompt path="~/posts" command="ls -la" /></p>
  <h1 style="margin-top:0.5rem">posts/</h1>

  {tags.length > 0 && (
    <p>
      <span class="muted">tags: </span>
      <span class="tag-list">
        {tags.map((t) => <TagChip tag={t} />)}
      </span>
    </p>
  )}

  {years.map((y) => (
    <section style="margin-top:1.5rem">
      <h2>{y}</h2>
      {byYear.get(y)!.map((p) => (
        <PostCard
          href={`${base}/posts/${p.id}`}
          title={p.data.title}
          date={p.data.date}
          description={p.data.description}
          category={p.data.category}
          tags={p.data.tags}
          lesenswert={p.data.lesenswert}
        />
      ))}
    </section>
  ))}

  {posts.length === 0 && <p class="muted">No posts yet.</p>}
</Base>
