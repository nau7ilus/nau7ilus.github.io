---
import Base from "../layouts/Base.astro";
import AsciiBanner from "../components/AsciiBanner.astro";
import Prompt from "../components/Prompt.astro";
import BoxFrame from "../components/BoxFrame.astro";
import PostCard from "../components/PostCard.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const posts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);
---

<Base>
  <AsciiBanner />

  <h1 class="sr-only">
    Filip Zieliński — Cybersecurity Notebook &amp; CTF Writeups
  </h1>

  <p style="margin-top:1.5rem">
    <strong>nau7ilus</strong> is the personal cybersecurity notebook of
    <strong>Filip Zieliński</strong>. I publish detailed CTF writeups,
    bug-bounty notes and side-project logs.
  </p>

  <p>
    See the <a href={`${base}/projects`}>projects</a> page for longer-running tooling
    and the <a href={`${base}/cv`}>cv</a> for a quick professional summary, or grab
    the <a href={`${base}/rss.xml`}>RSS feed</a>
    to follow new writeups.
  </p>

  <h2 class="terminal-heading">
    <Prompt path="~" command="ls posts/ | head -5" />
  </h2>

  {
    posts.length === 0 ? (
      <p class="muted">
        No posts yet.{" "}
        <code>$ touch src/content/posts/&lt;your-first-post&gt;.md</code>
      </p>
    ) : (
      <div>
        {posts.map((p) => (
          <PostCard
            href={`${base}/posts/${p.id}`}
            title={p.data.title}
            date={p.data.date}
            description={p.data.description}
            category={p.data.category}
            tags={p.data.tags}
            lesenswert={p.data.lesenswert}
          />
        ))}
      </div>
    )
  }

  <p style="margin-top:1rem">
    &rarr; <a href={`${base}/posts`}>all posts</a>
    &middot; <a href={`${base}/projects`}>projects</a>
    &middot; <a href={`${base}/cv`}>cv</a>
  </p>

  <h2 class="terminal-heading">
    <Prompt path="~" command="cat contact" cursor />
  </h2>
  <ul class="muted" style="list-style: none; padding-left: 0">
    <li>
      github&nbsp;&nbsp;: <a href="https://github.com/nau7ilus"
        >github.com/nau7ilus</a
      >
    </li>
    <li>
      mail&nbsp;&nbsp;&nbsp;&nbsp;: filip [at] fzielinski.dev (PGP: <a
        href={`${base}/pgp.txt`}>key</a
      >)
    </li>
    <li>
      htb&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;: <a
        href="https://profile.hackthebox.com/profile/019c9cff-3fe5-72d7-adaa-58ad3c8e51e8"
        >profile.hackthebox.com</a
      >
    </li>
  </ul>
</Base>
