---
import Base from "../layouts/Base.astro";
import BoxFrame from "../components/BoxFrame.astro";
import ProjectCard from "../components/ProjectCard.astro";
import Prompt from "../components/Prompt.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const featuredProjects = (
  await getCollection("projects", ({ data }) => data.featured)
).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="cv" description="Curriculum vitae of Filip Zieliński">
  <div
    class="no-print"
    style="display:flex; justify-content:space-between; align-items:baseline; flex-wrap:wrap; gap:0.5rem"
  >
    <Prompt path="~" command="cat cv.txt" />
    <a class="download-badge" href={`${base}/cv.pdf`} download
      >[ download .pdf ]</a
    >
  </div>

  <header
    style="display:grid; grid-template-columns: 140px 1fr; gap:1.5rem; align-items:center; margin-top:1rem"
  >
    <img
      src={`${base}/photo.jpg`}
      alt="Portrait of Filip Zieliński"
      width="140"
      height="140"
      style="border-radius: 4px; border: 1px solid var(--surface1); object-fit: cover; background: var(--mantle)"
      onerror="this.style.visibility='hidden'"
    />
    <div>
      <h1 style="margin:0">Filip Zieliński</h1>
      <p class="muted" style="margin:0.5rem 0 0">
        filip [at] fzielinski.dev &middot;
        <a href="https://github.com/nau7ilus">github</a> &middot;
        <a href="https://linkedin.com/in/filip-zieli">linkedin</a> &middot;
        <a href={`${base}/pgp.txt`}>pgp</a>
      </p>
    </div>
  </header>

  <section>
    <h2>profil</h2>
    <p>
      IT-Systems Engineering Student am HPI mit Schwerpunkt Offensive Security
      und Linux-Infrastruktur
    </p>
  </section>

  <section>
    <h2>ausbildung</h2>

    <BoxFrame>
      <p
        style="margin:0; display:flex; align-items:center; gap:0.6rem; flex-wrap:wrap"
      >
        <strong>Hasso-Plattner-Institut</strong>
        <span class="muted">
          &middot; Okt. 2025 &ndash; heute &middot; Potsdam</span
        >
      </p>
      <p class="muted" style="margin:0.1rem 0 0; font-style:italic">
        B.Sc. IT-Systems Engineering
      </p>
      <ul style="margin-top:0.5rem; margin-bottom:0">
        <li>
          <strong>Klubsprecher</strong> des CoderDojo-Klubs: Programmierkurse f&uuml;r
          ca. 20 Kinder/Jugendliche (5&ndash;17 J.)
        </li>
      </ul>
    </BoxFrame>

    <BoxFrame>
      <p
        style="margin:0; display:flex; align-items:center; gap:0.6rem; flex-wrap:wrap"
      >
        <strong>Humboldt-Gymnasium Potsdam</strong>
        <span class="muted">
          &middot; Aug. 2023 &ndash; Jun. 2025 &middot; Potsdam</span
        >
      </p>
      <p class="muted" style="margin:0.1rem 0 0; font-style:italic">
        Allgemeine Hochschulreife &mdash; Notendurchschnitt: <strong>1,3</strong
        >
      </p>
      <ul style="margin-top:0.5rem; margin-bottom:0">
        <li>
          <strong>Leistungsf&auml;cher:</strong> Informatik (Note 1), Mathematik (Note
          1&minus;)
        </li>
      </ul>
    </BoxFrame>
  </section>

  <section>
    <h2>praktische erfahrung</h2>

    <BoxFrame>
      <p
        style="margin:0; display:flex; align-items:center; gap:0.6rem; flex-wrap:wrap"
      >
        <strong>FISU World University Games 2025</strong>
        <span class="muted"> &middot; Jul. 2025 &middot; Berlin</span>
      </p>
      <p class="muted" style="margin:0.1rem 0 0; font-style:italic">
        Venue IT Manager
      </p>
      <ul style="margin-top:0.5rem; margin-bottom:0">
        <li>
          Unterst&uuml;tzung der IT-Infrastruktur an den Hauptspielst&auml;tten
          in Berlin: Einrichtung und Betreuung betrieblicher Endger&auml;te
          (Laptops, iPhones)
        </li>
        <li>
          Schulung und Koordination von <strong>5 IT-Volunteers</strong>;
          Schnittstelle zur internationalen Presse (DE/EN)
        </li>
      </ul>
    </BoxFrame>

    <BoxFrame>
      <p
        style="margin:0; display:flex; align-items:center; gap:0.6rem; flex-wrap:wrap"
      >
        <strong>DB Systel GmbH</strong>
        <span class="muted">
          &middot; Okt. 2024 &ndash; Nov. 2024 &middot; Berlin</span
        >
      </p>
      <p class="muted" style="margin:0.1rem 0 0; font-style:italic">
        Praktikant (Frontend-Entwicklung)
      </p>
      <ul style="margin-top:0.5rem; margin-bottom:0">
        <li>
          Entwicklung einer digitalen Bahnhofstafel mit Echtzeitdaten in
          TypeScript/Angular; Komponentenarchitektur und API-Integration
        </li>
      </ul>
    </BoxFrame>

    <BoxFrame>
      <p
        style="margin:0; display:flex; align-items:center; gap:0.6rem; flex-wrap:wrap"
      >
        <strong>Rundfunk Berlin-Brandenburg (rbb)</strong>
        <span class="muted">
          &middot; Jun. 2022 &ndash; Jul. 2022 &middot; Potsdam</span
        >
      </p>
      <p class="muted" style="margin:0.1rem 0 0; font-style:italic">
        Praktikant (Informationssicherheit)
      </p>
      <ul style="margin-top:0.5rem; margin-bottom:0">
        <li>
          Mitarbeit an 3 IT-Risikoanalysen interner Anwendungen (Threat
          Modeling)
        </li>
        <li>
          Web-Applikation zur Automatisierung von IT-Risikobewertungen (Ersatz
          f&uuml;r manuelle Excel-Pipeline)
        </li>
      </ul>
    </BoxFrame>
  </section>

  <section>
    <h2>erfolge</h2>

    <h3 style="font-size:0.95rem; color:var(--peach); margin-top:1.5rem">
      write-ups &amp; disclosures
    </h3>
    <ul>
      <li>
        <a href={`${base}/posts/2025-06-edtech-stored-xss`}
          >Stored XSS in einer Schul-Lernplattform (DACH-EdTech)</a
        >
        &middot; Responsible Disclosure &middot; Vendor auf Wunsch anonymisiert &middot;
        Jun. 2025
      </li>
      <li>
        <a href={`${base}/posts/2025-05-pcg-hexmonitoring`}>Hexmonitoring</a> (Mobile/Flutter,
        mTLS-Bypass) &middot; Write-up zur PCG-2025-L&ouml;sung &middot; Mai 2025
      </li>
      <li>
        <a href={`${base}/posts/2024-01-insobank-insomnihack-2024`}>InsoBank</a> (Web,
        Race + DECIMAL-Precision) &middot; Insomni'hack Teaser &middot; Jan. 2024
      </li>
    </ul>

    <h3 style="font-size:0.95rem; color:var(--peach); margin-top:1.5rem">
      wettbewerbe
    </h3>
    <ul>
      <li>
        <strong>2. Platz</strong>, Platypwn (HPI-internes CTF) &middot; Nov.
        2025
      </li>
      <li>
        <strong>1. Platz</strong>, <a href="https://potsdam-cyber-games.de"
          >Potsdam Cyber Games</a
        > (Kategorie Sch&uuml;ler), HPI &middot; Mai 2025
      </li>
      <li>
        <strong>Top 10&thinsp;%</strong> von ca. 470 Teams, <a
          href="https://ctftime.org/event/2139/">Insomni'hack Teaser 2024</a
        > (Team Platypwnies) &middot; Jan. 2024
      </li>
      <li>
        <strong>1. Preis + Sonderpreis</strong>, Bundeswettbewerb Informatik 42
        &middot; <a
          href="https://github.com/nau7ilus/BwInf42/tree/master#1-runde"
          >Dokumentation</a
        > &middot; 2023/24
      </li>
    </ul>
  </section>

  <section>
    <h2>projekte</h2>

    {
      featuredProjects.length === 0 ? (
        <p class="muted">No featured projects yet.</p>
      ) : (
        featuredProjects.map((p) => (
          <>
            <ProjectCard project={p.data} base={base} compact />
            <div style="height:1rem" />
          </>
        ))
      )
    }
  </section>

  <section>
    <h2>kenntnisse</h2>
    <ul>
      <li>
        <strong>Infrastruktur:</strong> Linux &middot; Docker &middot; Git &middot;
        VPS-Administration &middot; Reverse Proxy &middot; Grafana
      </li>
      <li>
        <strong>Programmierung:</strong> Node.js &middot; Python &middot; Django &middot;
        TypeScript/Angular &middot; Java &middot; REST-APIs
      </li>
      <li>
        <strong>Security:</strong> Burp Suite &middot; Ghidra &middot; OWASP Top 10
      </li>
      <li>
        <strong>Sprachen:</strong> Deutsch (C2) &middot; Englisch (C1) &middot; Polnisch
        (B2) &middot; Russisch &amp; Ukrainisch (Muttersprachen)
      </li>
    </ul>
  </section>

  <p class="muted no-print" style="margin-top:2rem; font-size:0.85rem">
    Vollst&auml;ndige Version im
    <a href={`${base}/cv.pdf`}>PDF-Download</a>.
  </p>
</Base>
