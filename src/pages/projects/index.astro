---
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import Prompt from '../../components/Prompt.astro';
import { getCollection, render } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const projects = (await getCollection('projects')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const rendered = await Promise.all(
  projects.map(async (p) => ({ p, Content: (await render(p)).Content })),
);
---
<Base title="projects" description="Things I've built.">
  <p><Prompt path="~/projects" command="ls" /></p>
  <h1>projects/</h1>

  {projects.length === 0 && <p class="muted">No projects yet.</p>}

  {rendered.map(({ p, Content }) => (
    <>
      <ProjectCard project={p.data} base={base}>
        <Content />
      </ProjectCard>
      <div style="height:1.5rem"></div>
    </>
  ))}
</Base>
